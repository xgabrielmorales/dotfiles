{
  "$schema": "https://f.jstanger.dev/github/ironbar/schema.json",
  "name": "main",
  "position": "bottom",
  "height": 32,
  "popup_autohide": true,
  "start": [
    {
      "type": "custom",
      "class": "launcher-box",
      "bar": [
        {
          "type": "button",
          "name": "launcher-btn",
          "label": "î§Œ",
          "on_click": "!~/.config/rofi/bin/rofi-launcher/launcher.sh"
        }
      ]
    },
    {
      "type": "launcher",
      "show_icons": true,
      "show_names": false,
      "icon_size": 24
    }
  ],
  "center": [
    {
      "type": "music",
      "format": "{title} - {artist}",
      "truncate": {
        "mode": "end",
        "max_length": 50
      },
      "truncate_popup_title": {
        "mode": "end",
        "max_length": 25
      },
      "truncate_popup_artist": {
        "mode": "end",
        "max_length": 25
      },
      "truncate_popup_album": {
        "mode": "end",
        "max_length": 25
      }
    }
  ],
  "end": [
    {
      "type": "tray",
      "icon_size": 16
    },
    {
      "type": "sys_info",
      "format": [
        "CPU {temp_c@k10temp Tctl:.0}Â°C"
      ],
      "interval": {
        "temps": 5
      }
    },
    {
      "type": "brightness",
      "format": "{percentage}%",
      "icon_label": "ó°ƒ  ",
      "use_default_profiles": false,
      "mode": {
        "type": "systemd",
        "subsystem": "backlight",
        "name": "amdgpu_bl1"
      },
      "tooltip": "Brightness"
    },
    {
      "type": "battery",
      "format": "{percentage}%",
      "show_icon": true
    },
    {
      "type": "bluetooth",
      "icon_size": 28,
      "popup": {
        "header": " ïŠ” Bluetooth",
        "disabled": "{adapter_status}"
      },
      "format": {
        "enabled": "ïŠ” On",
        "disabled": "ïŠ” Off",
        "connected": "ïŠ” {device_alias}",
        "connected_battery": "ïŠ” {device_alias} â€¢ {device_battery_percent}%"
      }
    },
    {
      "type": "volume",
      "name": "vol-in",
      "show_sinks": false,
      "show_sources": true,
      "show_monitors": false,
      "on_click_left": "source_module --toggle",
      "on_click_right": "ironbar bar main toggle-popup vol-in",
      "truncate_popup": {
        "mode": "end",
        "max_length": 25
      },
      "popup_orientation": "vertical",
      "on_click_middle": "source_module --toggle",
      "on_scroll_up": "source_module --inc",
      "on_scroll_down": "source_module --dec"
    },
    {
      "type": "volume",
      "name": "vol-out",
      "show_sinks": true,
      "show_sources": false,
      "show_monitors": false,
      "on_click_left": "sink_module --toggle",
      "on_click_right": "ironbar bar main toggle-popup vol-out",
      "truncate_popup": {
        "mode": "end",
        "max_length": 25
      },
      "popup_orientation": "vertical",
      "on_click_middle": "sink_module --toggle",
      "on_scroll_up": "sink_module --inc",
      "on_scroll_down": "sink_module --dec"
    },
    {
      "type": "clock",
      "format": "î¤¹ %H:%M",
      "tooltip": "{{1000:date '+%Y-%m-%d %H:%M:%S'}}"
    },
    {
      "type": "custom",
      "name": "power-menu",
      "class": "power-menu",
      "tooltip": "Power",
      "bar": [
        {
          "type": "button",
          "name": "power-btn",
          "label": "î§€",
          "on_click": "popup:toggle"
        }
      ],
      "popup": [
        {
          "type": "box",
          "orientation": "vertical",
          "widgets": [
            {
              "type": "button",
              "class": "power-menu-btn",
              "label": "ï€£ Lock    ",
              "on_click": "!waylock -init-color 0x1e222a -input-color 0x98c379 -fail-color 0xe06c75"
            },
            {
              "type": "button",
              "class": "power-menu-btn",
              "label": "ï†† Sleep   ",
              "on_click": "!systemctl suspend"
            },
            {
              "type": "button",
              "class": "power-menu-btn",
              "label": "ï‚‹ Logout  ",
              "on_click": "!labwc --exit"
            },
            {
              "type": "button",
              "class": "power-menu-btn",
              "label": "ï€¡ Restart ",
              "on_click": "!systemctl reboot"
            },
            {
              "type": "button",
              "class": "power-menu-btn",
              "label": "ï€‘ Shutdown",
              "on_click": "!systemctl poweroff"
            }
          ]
        }
      ]
    }
  ]
}
