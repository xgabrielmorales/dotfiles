[user]
    name = Gabriel Morales
    email = gabrielmorales1@protonmail.com
    signingkey = ~/.ssh/Personal/IdentityFiles/id_ed25519.pub

[alias]
    lod = log --graph --pretty=format:'%C(yellow)%h%C(reset) %C(red)%aN%C(reset) %C(green)%ar%C(reset) %C(yellow)%D%C(reset)%n%s%n' --use-mailmap
    s = status
    staged = diff --staged

[branch]
    sort = -committerdate

[color "status"]
    added = yellow
    changed = green
    untracked = cyan

[commit]
    gpgsign = true
    verbose = true


[core]
    editor = nvim

[diff]
    context = 5


[fetch]
    all = true
    prune = true
    pruneTags = true

[gpg]
    format = ssh

[help]
    autocorrect = immediate

[includeIf "gitdir:~/Documents/Work/"]
    path = ~/Documents/Work/.gitconfig

[init]
    defaultBranch = trunk

[log]
    date = iso-local
    mailmap = true

[delta]
    features = xgm-theme

[delta "xgm-theme"]
    syntax-theme = OneHalfDark
    line-numbers = true

    file-style = omit

    hunk-header-decoration-style = underline overline "#E5C07B"
    hunk-header-file-style = "#E5C07B"
    hunk-header-style = file line-number

    zero-style = dim syntax

    minus-emph-style = bold "#E06C75" "#3f0001"
    minus-empty-line-marker-style = normal "#3f0001"
    minus-non-emph-style = dim "#E06C75"
    minus-style = "#E06C75"

    plus-emph-style = bold "#98C379" "#002800"
    plus-empty-line-marker-style = normal "#002800"
    plus-non-emph-style = dim "#98C379"
    plus-style = "#98C379"

    whitespace-error-style = reverse "#E06C75"

    line-numbers-left-format = "{nm:^3} "
    line-numbers-left-style = "#5C6370"
    line-numbers-minus-style = "#E06C75"
    line-numbers-plus-style = "#98C379"
    line-numbers-right-format = "{np:^3} "
    line-numbers-right-style = "#5C6370"

[pager]
    diff = delta

[pull]
    rebase = true

[push]
    autoSetupRemote = true
    default = simple

[rebase]
    autoStash = true
    missingCommitsCheck = warn
    updateRefs = true

[status]
    showStash = true
